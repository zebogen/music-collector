DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5433/music_collector
DATABASE_URL_UNPOOLED=
SESSION_SECRET=replace-with-a-long-random-string

AUTH0_DOMAIN=your-tenant.us.auth0.com
AUTH0_CLIENT_ID=your-auth0-client-id
AUTH0_CLIENT_SECRET=your-auth0-client-secret
# Optional override for environments where request host detection is not reliable.
# Leave empty for local dev. Example: https://music-collector.example.com
AUTH0_APP_BASE_URL=
AUTH0_REDIRECT_URI=http://127.0.0.1:5173/auth/callback
AUTH0_LOGOUT_RETURN_TO=http://127.0.0.1:5173

SPOTIFY_CLIENT_ID=your-spotify-client-id
SPOTIFY_CLIENT_SECRET=your-spotify-client-secret
SPOTIFY_REDIRECT_URI=http://127.0.0.1:5173/auth/spotify/callback

BASIC_AUTH_USERNAME=admin
BASIC_AUTH_PASSWORD=changeme
